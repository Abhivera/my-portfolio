{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/notepad/*.ts": {
      "maxDuration": 30
    },
    "api/goal/*.ts": {
      "maxDuration": 15
    },
    "api/blog/*.ts": {
      "maxDuration": 15
    }
  }
}
