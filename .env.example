# MongoDB (use your Atlas connection string)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=portfolio

# Shared password for /notepad (login uses ONLY this — must match on Vercel Production)
NOTEPAD_PASSWORD=change-me-to-a-strong-password
NOTEPAD_SESSION_SECRET=change-me-use-a-long-random-string-at-least-32-chars

# Separate password for /blog/admin (seeded into DB on first sign-in)
BLOG_PASSWORD=change-me-to-a-different-strong-password
BLOG_SESSION_SECRET=change-me-another-long-random-string-at-least-32-chars

# Vercel: add the same variables in Project → Settings → Environment Variables
# (no separate backend — /api/notepad/*, /api/goal/*, and /api/blog/* run as serverless functions)
