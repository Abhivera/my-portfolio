# MongoDB (use your Atlas connection string)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=portfolio

# Shared password for /notepad (login uses ONLY this — must match on Vercel Production)
NOTEPAD_PASSWORD=change-me-to-a-strong-password
NOTEPAD_SESSION_SECRET=change-me-use-a-long-random-string-at-least-32-chars

# Separate password for /goal
GOAL_PASSWORD=change-me-to-a-different-strong-password
GOAL_SESSION_SECRET=change-me-another-long-random-string-at-least-32-chars

# Separate password for /blog/admin (seeded into DB on first sign-in)
BLOG_PASSWORD=change-me-to-a-different-strong-password
BLOG_SESSION_SECRET=change-me-another-long-random-string-at-least-32-chars

# Google Drive — notepad attachments only (PDF, docs, images, media; max 10 MB, 20/note)
# Blog cover images still use MongoDB — not Drive.
# 1. Create a Google Cloud service account with the Drive API enabled
# 2. Create a Drive folder and share it with the service account email (Editor)
# 3. Paste the folder ID from the Drive URL: https://drive.google.com/drive/folders/FOLDER_ID
# 4. Use the service account JSON: client_email + private_key (keep \n escaped as \\n in .env)
GOOGLE_DRIVE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_DRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id

# Vercel: add the same variables in Project → Settings → Environment Variables
# (no separate backend — /api/notepad/*, /api/goal/*, and /api/blog/* run as serverless functions)
